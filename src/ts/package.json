{
  "name": "alchemy-logging",
  "version": "0.0.0-REPLACEME",
  "description": "Alchemy Logging implementation in NodeJS/TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "NODE_ENV=test nyc mocha --exit --require ts-node/register 'test/**/*.ts'",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "clean": "rm -rf dist",
    "build": "tsc",
    "prepare": "npm run build",
    "repl": "ts-node"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:IBM/alchemy-logging.git"
  },
  "nyc": {
    "extension": [
      ".ts",
      ".tsx"
    ],
    "exclude": [
      "**/*.d.ts",
      "coverage/**",
      "dist/**",
      "test/**"
    ],
    "reporter": [
      "text-summary",
      "html"
    ],
    "all": true
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Gabe Goodhart",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/chai": "^5.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^25.5.0",
    "chai": "^4.2.0",
    "deep-equal": "^2.0.5",
    "eslint": "^10.0.0",
    "memory-streams": "^0.1.3",
    "mocha": "^11.1.0",
    "nyc": "^18.0.0",
    "rewire": "^9.0.0",
    "ts-node": "^10.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.0.0"
  }
}
